# ── Browser (Vite) ─────────────────────────────────────────
# fixture = bundled golden-fixture provider (default, safe)
# bff     = browser talks only to our own Express BFF
VITE_DATA_MODE=fixture
VITE_BFF_BASE_URL=http://localhost:8787/api

# ── BFF (server/.env or process env — NEVER committed) ─────
# fixture = controlled golden fixture; live = FuFirE upstream
FUFIRE_MODE=fixture
PORT=8787
RULESET_ID=zwds.fufire.core-seed.v1

# Live upstream — server-side only, never exposed to the client.
# All values are required in live mode. The auth header/scheme must come
# from the approved FuFirE integration contract; the application does not guess it.
# Put REAL values in a gitignored .env (copy this file), never here.
# FUFIRE_BASE_URL=
# FUFIRE_API_KEY=
# FUFIRE_AUTH_HEADER=
# FUFIRE_AUTH_SCHEME=
FUFIRE_TIMEOUT_MS=15000
# Live geocode endpoint (server-side only). The real FuFirE contract is:
#   POST /v1/geocode  body { "place": "<query>" }  -> 200 single match | 422 ambiguous candidates.
# Set this (in your gitignored .env, uncommented) to enable live geocoding; left unset in fixture mode.
# FUFIRE_GEOCODE_PATH=/v1/geocode

# LLM synthesis (REQ-015) ships DISABLED and fail-closed. The pipeline exists, but enabling
# it requires a genuinely source-reviewed rules corpus — the default has none (SOURCE_NEEDED),
# so unsourced interpretation is never emitted. To enable (only with a real reviewed corpus):
#   LLM_ENABLED=true
#   LLM_CORPUS_STATUS=SOURCE_REVIEWED
#   LLM_CORPUS_PATH=/abs/path/to/reviewed-corpus.json   # validated against the schema at boot
#   LLM_CORPUS_SHA256=<64-hex sha256 of that file>       # pinned; a mismatch refuses boot
#   LLM_API_KEY=<anthropic key>                          # server-side only, never logged
#   # LLM_MODEL=claude-sonnet-5   (default)   # LLM_TIMEOUT_MS=30000 (default)
# Missing/invalid/hash-mismatched corpus => boot refuses; any ungrounded synthesis =>
# rejected and the deterministic sections are served instead.
LLM_ENABLED=false

# Optional: enables the server-side PDF route when a Chromium runtime exists.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Optional strict same-origin allowlist for browser writes.
# ALLOWED_ORIGIN=http://localhost:5173

# ── Single-service production deploy (e.g. Railway) ─────────
# The BFF serves the built SPA and /api from the same origin, so for a LIVE
# user-facing deploy the browser must call the BFF (not use bundled fixtures):
#   VITE_DATA_MODE=bff            # else end users see DEMO fixture data, not live
#   VITE_BFF_BASE_URL=/api        # same-origin relative; NOT the FuFirE upstream URL
#   FUFIRE_MODE=live + FUFIRE_BASE_URL/API_KEY/AUTH_HEADER + FUFIRE_GEOCODE_PATH=/v1/geocode
# VITE_* are build-time — changing them requires a rebuild/redeploy to take effect.

# ── Source-governance (authoritative status) ───────────────
# The report is authoritative (SOURCE_REVIEWED, no "not authoritative" notice) ONLY when a
# named source-governance reviewer has signed off the ruleset by pinning its exact content
# digest. Absent by default -> the chart stays SOURCE_NEEDED / not-authoritative. To enable
# (only with a genuine human sign-off — never fabricate a hash or a reviewer):
#   RULESET_ATTESTATION_PATH=/abs/path/to/ruleset-attestation.json  # validated at boot
#   RULESET_ATTESTATION_SHA256=<64-hex sha256 of that file>          # pinned; mismatch refuses boot
# The attestation's reviewedRulesetSha256 must EQUAL the live ruleset_sha256, or the chart is
# NOT elevated (fail-closed). A declared-but-unverifiable attestation refuses boot.
